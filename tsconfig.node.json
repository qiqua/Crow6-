  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "outDir": "dist-electron",
    "skipLibCheck": true
  },
  "include": ["electron/**/*.ts", "vite.config.ts"]
}
